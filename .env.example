# Copy to .env and fill in. Never commit the real .env.

# Groq API key — required for chat completions (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Mem0 API key — required for long-term memory retrieval/storage (https://app.mem0.ai)
MEM0_API_KEY=your_mem0_api_key_here

# Optional: point the frontend at an API base other than the relative /api/* URLs.
# Leave unset in production (Netlify serves the function at /api/*).
# For a separate local API server, e.g.: http://localhost:8888
# REACT_APP_API_URL=http://localhost:8888
